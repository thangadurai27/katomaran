# Server
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-app.vercel.app
# Alias supported on Render:
# CLIENT_URL=https://your-app.vercel.app

# MongoDB Atlas — https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://xxxx:xxxx@cluster0.xxxxx.mongodb.net/katomaran?retryWrites=true&w=majority

# JWT — use long random strings (openssl rand -hex 32)
JWT_SECRET=xxxx
JWT_REFRESH_SECRET=xxxx
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxx
GEMINI_MODEL=gemini-2.5-flash

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=xxxx@gmail.com
EMAIL_PASS=xxxx
EMAIL_FROM=SnapLink AI <noreply@yourdomain.com>

# Short links — your Render backend URL + /r/
SHORT_URL_BASE=https://your-api.onrender.com/r/
